# Copy this file to `.env` in the same folder (project root CS661/).
# Paste your OpenAlex API key from https://openalex.org/settings/api
#
#   copy .env.example .env
#   notepad .env
#
# NEVER commit `.env` — it is listed in .gitignore.

OPENALEX_API_KEY=paste_your_key_here

# ETL memory: low (default, laptop-friendly) | high (overnight only)
INDIA_ETL_MEMORY=low
